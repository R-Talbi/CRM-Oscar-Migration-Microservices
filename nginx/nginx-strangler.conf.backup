
# NGINX Config basierend auf Strangler Pattern


events {
    worker_connections 1024;
}

http {
    # Logging
    log_format strangler '$remote_addr [$time_local] "$request" '
                        'backend=$backend_used';

    access_log /var/log/nginx/strangler.log strangler;
    error_log /var/log/nginx/error.log warn;

    # Upstream Definitionen
    upstream django_monolith {
        server host.docker.internal:8000;
    }

    upstream offers_microservice {
        server host.docker.internal:8001;
    }

    server {
        listen 80;
        server_name localhost;

        # Health Check
        location /health {
            return 200 "Gateway OK\n";
            add_header Content-Type text/plain;
        }

        # Status
        location /strangler-status {
            return 200 '{"phase":"1","monolith":"100%","microservice":"0%"}';
            add_header Content-Type application/json;
        }

        # Offers API Routing
        location /api/offers {
            # Default: Monolith
            set $backend_used "monolith";

            # Header Override für Testing
            if ($http_x_use_microservice = "true") {
                set $backend_used "microservice";
            }

            # Routing
            if ($backend_used = "microservice") {
                proxy_pass http://offers_microservice;
            }
            if ($backend_used = "monolith") {
                proxy_pass http://django_monolith;
            }

            # Headers
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;

            # Debug Header
            add_header X-Backend-Used $backend_used always;
        }

        # Default: Alles zum Monolith
        location / {
            proxy_pass http://django_monolith;
            proxy_set_header Host $host;
            add_header X-Backend-Used "monolith" always;
        }
    }
}

